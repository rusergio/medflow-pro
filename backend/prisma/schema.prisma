// MedFlow Pro - Modelo para Portugal / SNS / UE
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DOCTOR
  NURSE
  ADMIN
}

enum UtenteStatus {
  ESTAVEL
  CRITICO
  EM_OBSERVACAO
  ALTA
}

enum TipoAtendimento {
  CONSULTA_EXTERNA
  URGENCIA
  INTERNAMENTO
  EXAME_COMPLEMENTAR
}

enum PrioridadeTriagem {
  VERMELHO
  LARANJA
  AMARELO
  VERDE
  AZUL
}

enum AppointmentType {
  PRIMEIRA_CONSULTA
  SEGUIMENTO
  CONSULTA
  RETORNO
  EXAME
  EMERGENCIA
}

enum AppointmentStatus {
  AGENDADA
  CONFIRMADA
  CANCELADA
  FALTA
  REALIZADA
}

enum OrigemMarcacao {
  MEDICO_FAMILIA
  INTERNO
  REFERENCIADO
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  pinHash   String?
  role      UserRole @default(DOCTOR)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  medicalRecords MedicalRecord[]

  @@map("users")
}

model Especialidade {
  id        String   @id @default(uuid())
  nome      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@map("especialidades")
}

model Patient {
  id                  String           @id @default(uuid())
  nome                String
  numeroUtente        String?
  numeroCc            String?
  nif                 String?
  dataNascimento      DateTime
  sexo                String
  nacionalidade       String?
  registoProvisorio   Boolean          @default(false)
  numeroProvisorio    String?
  tipoDocumento       String?
  numeroDocumento     String?
  paisOrigem          String?
  telemovel           String
  telefoneAlternativo String?
  email               String?
  rua                 String?
  codigoPostal        String?
  localidade          String?
  concelho            String?
  distrito            String?
  processoClinicoNum  String?
  unidadeHospitalar   String?
  medicoFamilia       String?
  centroSaude         String?
  tipoAtendimento     TipoAtendimento?
  dataRegisto         DateTime         @default(now())
  alergias            String?
  doencasCronicas     String?
  medicacaoHabitual   String?
  grupoSanguineo      String?
  observacoesClinicas String?
  status              UtenteStatus     @default(ESTAVEL)
  quarto              String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  appointments Appointment[]
  medicalRecords MedicalRecord[]
  triagens      Triagem[]

  @@unique([numeroUtente])
  @@unique([numeroProvisorio])
  @@index([numeroUtente])
  @@index([numeroProvisorio])
  @@index([processoClinicoNum])
  @@map("patients")
}

model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  especialidadeId String?
  especialidade   Especialidade?    @relation(fields: [especialidadeId], references: [id])
  doctorId        String
  doctor          User              @relation(fields: [doctorId], references: [id])
  date            DateTime
  sala            String?
  tipo            AppointmentType
  status          AppointmentStatus @default(AGENDADA)
  origem          OrigemMarcacao?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@index([date])
  @@map("appointments")
}

model Triagem {
  id               String           @id @default(uuid())
  patientId        String
  patient          Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  prioridade       PrioridadeTriagem
  sinaisVitais     String?
  dataHoraAdmissao DateTime         @default(now())
  profissionalId   String?
  observacoes      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([patientId])
  @@index([prioridade])
  @@map("triagens")
}

model MedicalRecord {
  id         String   @id @default(uuid())
  patientId  String
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId   String
  doctor     User     @relation(fields: [doctorId], references: [id])
  date       DateTime @default(now())
  diagnosis  String
  notes      String
  medication String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@map("medical_records")
}
